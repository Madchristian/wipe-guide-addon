<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

    <!-- WipeGuide Settings Panel (wird in Settings.lua befüllt) -->
    <Frame name="WipeGuideSettingsPanel" hidden="true">
        <Size x="600" y="400"/>
        <Layers>
            <Layer level="ARTWORK">
                <FontString name="$parentTitle" parentKey="title"
                            inherits="GameFontNormalLarge" text="WipeGuide Einstellungen">
                    <Anchors>
                        <Anchor point="TOPLEFT" x="16" y="-16"/>
                    </Anchors>
                </FontString>
                <FontString name="$parentVersion" parentKey="version"
                            inherits="GameFontNormalSmall" text="">
                    <Color r="0.5" g="0.5" b="0.5"/>
                    <Anchors>
                        <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT"
                                relativeTo="$parentTitle" y="-4"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
    </Frame>
</Ui>
